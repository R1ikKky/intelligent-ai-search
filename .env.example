# Скопируйте в `.env` в корне репозитория и при необходимости измените значения.
# Docker Compose подхватывает переменные из `.env` автоматически.

# --- JWT (обязательны для backend, см. backend/src/config/validation.ts) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Тома контейнеров (по умолчанию диск D: на Windows) ---
# DOCKER_VOLUME_ROOT=D:/docker-data/intelligent-ai-search

# --- ETL (сервис `etl` в compose) ---
# ETL_SKIP=0
# Полный датасет: ETL_STE_LIMIT=0 и ETL_CONTRACT_LIMIT=0
# ETL_STE_LIMIT=20000
# ETL_CONTRACT_LIMIT=8000

# --- Прочее ---
# ELASTICSEARCH_INDEX=products
# AUTO_REINDEX_ON_START=true
